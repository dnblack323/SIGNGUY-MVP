# SignGuy AI development environment example.
# Placeholder values only. Do not put real keys in this file.

# Backend runtime (copy backend values into backend/.env for local development)
MONGO_URL=<mongodb-url>
DB_NAME=<database-name>
CORS_ORIGINS=<comma-separated-origins>
JWT_SECRET=<strong-local-development-jwt-secret>
JWT_ACCESS_TTL_MINUTES=<minutes>
APP_NAME=signguy-ai
ENV=development
AUTH_DEV_BYPASS=false

# EC16 / EC17 local AI gateway and Studio tools
# Current Studio and gateway execution is local-contract/mock unless a later provider path is implemented.
AI_ENABLED=false
EMERGENT_LLM_KEY=<emergent-llm-key>

# EC18 Business Assistant OpenAI Realtime voice
# Backend only. Never expose this to frontend code or browser storage.
OPENAI_API_KEY=<openai-api-key>
OPENAI_REALTIME_ENABLED=false
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_TIMEOUT_SECONDS=10
OPENAI_REALTIME_TURN_DETECTION=server_vad
OPENAI_REALTIME_PUSH_TO_TALK_DEFAULT=true
OPENAI_REALTIME_RATE_LIMIT_SESSIONS=10
OPENAI_REALTIME_RATE_LIMIT_WINDOW_SECONDS=60
ASSISTANT_TRANSCRIPT_RETENTION=conversation_policy

# Frontend runtime (copy frontend values into frontend/.env for local development)
# No provider API keys belong in frontend/.env.
REACT_APP_BACKEND_URL=http://localhost:8001
